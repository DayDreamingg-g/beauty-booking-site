generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model BookingRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  service   String
  master    String
  date      String
  comment   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}