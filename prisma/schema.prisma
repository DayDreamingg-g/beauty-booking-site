generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model BookingRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  service   String
  master    String
  date      String
  time      String?
  comment   String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String          @id @default(cuid())
  title       String
  price       String
  duration    String
  description String
  includes    String
  image       String          @default("/images/service-default.jpg")
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  portfolio   PortfolioItem[]
}

model Master {
  id          String          @id @default(cuid())
  name        String
  role        String
  image       String
  description String
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  portfolio   PortfolioItem[]
  reviews     Review[]
}

model PortfolioItem {
  id          String   @id @default(cuid())
  image       String
  serviceId   String
  masterId    String
  duration    String
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  master  Master  @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([masterId])
}

model Review {
  id        String   @id @default(cuid())
  name      String
  text      String
  rating    Int
  image     String?
  masterId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  master Master @relation(fields: [masterId], references: [id], onDelete: Cascade)

  @@index([masterId])
}